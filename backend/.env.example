PORT=5000
MONGODB_URI=mongodb://localhost:27017/lokl
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
# Google OAuth 2.0 web client ID (Google Cloud Console > Credentials).
# Same value goes in mobile/lib/core/constants/api_constants.dart (googleServerClientId).
GOOGLE_CLIENT_ID=

# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Optional. Leave empty to disable error tracking. If set, run `npm install @sentry/node`.
SENTRY_DSN=
# Number of reverse-proxy hops in front of this app (nginx/ALB/Cloudflare = usually 1).
# Leave at 0 for local dev / no proxy. Wrong value breaks rate-limiting and client IP logging.
TRUST_PROXY=0

# Only read by `npm run seed`, not by the app itself. Set these to a strong
# custom password before seeding any publicly-reachable database — otherwise
# the seed script falls back to the well-known defaults documented in DEPLOYMENT.md.
ADMIN_SEED_PASSWORD=
MEMBER_SEED_PASSWORD=
