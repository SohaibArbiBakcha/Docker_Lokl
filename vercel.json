{
  "installCommand": "npm install && npm install --prefix backend && npm install --prefix admin --include=dev",
  "buildCommand": "VITE_API_URL=/api/v1 npm run build:site",
  "outputDirectory": "site",
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/e/(.*)", "destination": "/open-event.html" },
    { "source": "/admin/assets/(.*)", "destination": "/admin/assets/$1" },
    { "source": "/admin/favicon.svg", "destination": "/admin/favicon.svg" },
    { "source": "/admin/icons.svg", "destination": "/admin/icons.svg" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" }
  ],
  "crons": [
    { "path": "/api/v1/internal/purge-pending-deletions", "schedule": "0 3 * * *" }
  ]
}
